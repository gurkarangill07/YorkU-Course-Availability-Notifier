DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
PORT=3000

# Monitor runtime
MONITOR_INTERVAL_SECONDS=60
SESSION_DURATION_MINUTES=90
VSB_REFRESH_INTERVAL_MINUTES=15
OWNER_ALERT_EMAIL=you@example.com

# VSB mode
VSB_SOURCE_MODE=browser
VSB_URL=https://your-vsb-url
VSB_USER_DATA_DIR=.data/vsb-profile
VSB_HEADLESS=false

# Gmail SMTP (use a Gmail App Password, not your normal account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_PASS_AUTH=your_auth_16_char_app_password
SMTP_FROM="CourseNotif <yourgmail@gmail.com>"

# Passwordless auth (email OTP)
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_FAILED_ATTEMPTS=5
AUTH_SESSION_DAYS=30
AUTH_COOKIE_SECURE=false
OTP_PEPPER=change_this_random_secret
