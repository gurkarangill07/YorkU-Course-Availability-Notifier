{
  "name": "coursenotif-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "CourseNotif monitoring worker logic with database-backed state and SMTP email notifications",
  "main": "src/worker.js",
  "scripts": {
    "web": "node src/apiServer.js",
    "web:local": "bash scripts/with-env.sh node src/apiServer.js",
    "db:schema:apply": "node scripts/apply-schema.js",
    "monitor:init-login": "node src/worker.js --init-login",
    "monitor:init-login:local": "bash scripts/with-env.sh node src/worker.js --init-login",
    "monitor:init-login:keep-open": "node src/worker.js --init-login --keep-open",
    "monitor:init-login:keep-open:local": "bash scripts/with-env.sh node src/worker.js --init-login --keep-open",
    "monitor:once": "node src/worker.js --once",
    "monitor:once:local": "bash scripts/with-env.sh node src/worker.js --once",
    "monitor:loop": "node src/worker.js",
    "monitor:loop:local": "bash scripts/with-env.sh node src/worker.js",
    "monitor:health": "node scripts/check-worker-health.js",
    "monitor:health:local": "bash scripts/with-env.sh node scripts/check-worker-health.js",
    "smoke": "node scripts/smoke-check.js",
    "test": "node --test test/*.test.js",
    "ci": "npm run smoke && node --test --test-isolation=none test/*.test.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.12.0",
    "playwright": "^1.51.1"
  }
}
